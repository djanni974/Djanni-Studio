{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"dev": {
			"persistent": true,
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"type-check": {
			"dependsOn": ["^type-check"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		}
	}
}
