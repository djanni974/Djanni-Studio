{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn"
			},
			"style": {
				"noNonNullAssertion": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			},
			"a11y": {
				"useFocusableInteractive": "warn",
				"useSemanticElements": "warn",
				"useAriaPropsForRole": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/dist",
			"!**/.turbo",
			"!**/pnpm-lock.yaml",
			"!**/.claude",
			"!**/public/sw.js",
			"!**/next-env.d.ts"
		]
	}
}
